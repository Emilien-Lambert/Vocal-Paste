# Hugging Face token — required to download the model without rate limits
# Get yours at https://huggingface.co/settings/tokens
HF_TOKEN=

# Time in seconds before unloading the model from RAM
# Lower values free RAM faster, higher values keep the model ready for instant use
MODEL_TIMEOUT=30

# Recording mode: 
# true  -> Hold key to record
# false -> Press once to start, once to stop
HOLD_TO_TALK=false

# Automatically paste the transcribed text (requires accessibility permissions on macOS)
# true  -> Paste text immediately after transcription
# false -> Only copy to clipboard
AUTO_PASTE=false
